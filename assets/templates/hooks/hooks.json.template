{
  "version": 1,
  "description": "Repo-local hooks for project-bedrock. Hooks stay thin: detect meaningful changes and trigger lightweight capture/update, never rebuild the full ontology.",
  "hooks": [
    {
      "name": "project-knowledge-sync",
      "event": "post-write",
      "command": "bedrock update --summary-file <repo-path>/.cursor/knowledge-sync.last.json --project <repo-path>"
    },
    {
      "name": "project-knowledge-session-start",
      "event": "session-start",
      "command": "bedrock sync --project <repo-path> && bedrock refresh-system --project <repo-path>"
    },
    {
      "name": "project-knowledge-stop",
      "event": "stop",
      "command": "bedrock sync --project <repo-path>"
    },
    {
      "name": "project-knowledge-pre-compact",
      "event": "preCompact",
      "command": "bedrock sync --project <repo-path>"
    }
  ]
}
