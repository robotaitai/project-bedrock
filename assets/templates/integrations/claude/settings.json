{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bedrock sync --project <repo-path> && bedrock refresh-system --project <repo-path>"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bedrock sync --project <repo-path>"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bedrock sync --project <repo-path>"
          }
        ]
      }
    ]
  }
}
