{
  "version": 1,
  "description": "Repo-local hook example for agents-rules knowledge sync.",
  "hooks": [
    {
      "name": "project-knowledge-sync",
      "event": "post-write",
      "command": "<path-to-agents-rules>/scripts/update-knowledge.sh --summary-file <repo-path>/.cursor/knowledge-sync.last.json <repo-path>"
    }
  ]
}
